    "example": "123456, г. Москва, ул. Ленина, д. 10"
  },
  {
    "step": "contact_email",
    "text": "📧 Email для обращений:",
    "type": "text",
    "required": true,
    "validate": "email",
    "example": "support@mysite.ru"
  },
  {
    "step": "site_purpose",
    "text": "🎯 Для чего предназначен сайт? (выберите все нужные):",
    "type": "multi_select",
    "options": [
      "✅ Продажа товаров",
      "✅ Предоставление услуг",
      "✅ Информационный портал",
      "✅ Блог / Медиа",
