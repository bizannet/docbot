    "hint": "Если выбрали «Другое» — напишите, что именно",
    "conditional": {
      "show_if": {
        "prohibited_actions": "✅ Другое (укажу вручную)"
      }
    }
  },
  {
    "step": "liability_limit",
    "text": "⚖️ Ограничение ответственности владельца:",
    "type": "single_select",
    "options": [
