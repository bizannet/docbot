[
  {
    "step": "site_name",
    "text": "🌐 Название сайта:",
    "type": "text",
    "required": true,
    "example": "Мой интернет-магазин",
    "hint": "Как называется ваш сайт"
  },
  {
    "step": "site_url",
    "text": "🔗 Адрес сайта (домен):",
    "type": "text",
    "required": true,
    "example": "https://mysite.ru",
    "hint": "Полный адрес с https://"
  },
  {
    "step": "operator_type",
    "text": "👤 Оператор персональных данных — кто вы:",
    "type": "single_select",
    "options": [
      "ИП",
      "ООО",
      "Физ. лицо (самозанятый)",
      "Физ. лицо (не самозанятый)"
    ],
    "required": true
  },
  {
    "step": "operator_name",
    "text": "📝 Полное наименование оператора:",
    "type": "text",
    "required": true,
    "example": "ИП Иванова Мария Петровна / ООО «Ромашка»"
  },
  {
    "step": "operator_inn",
    "text": "🔢 ИНН оператора:",
    "type": "text",
    "required": true,
    "validate": "inn",
    "example": "123456789012"
  },
  {
    "step": "operator_ogrn",
    "text": "🔢 ОГРН/ОГРНИП оператора:",
    "type": "text",
    "required": false,
    "validate": "ogrn",
    "example": "317774600000000",
    "skip_button": true,
    "conditional": {
      "show_if": {
        "operator_type": ["ИП", "ООО"]
      }
    }
  },
  {
    "step": "operator_address",
    "text": "🏠 Юридический адрес оператора:",
    "type": "text",
    "required": true,
    "example": "123456, г. Москва, ул. Ленина, д. 10"
  },
  {
    "step": "contact_email",
    "text": "📧 Email для обращений:",
    "type": "text",
    "required": true,
    "validate": "email",
    "example": "privacy@mysite.ru"
  },
  {
    "step": "data_purposes",
    "text": "🎯 Для чего собираете данные? (выберите все нужные):",
    "type": "multi_select",
    "options": [
      "✅ Оформление заказов",
      "✅ Обратная связь",
      "✅ Рассылка новостей",
      "✅ Аналитика сайта",
      "✅ Регистрация на сайте",
      "✅ Другое (укажу вручную)"
    ],
    "required": true
  },
  {
    "step": "data_purposes_other",
    "text": "📝 Укажите другие цели:",
    "type": "text",
    "required": false,
    "example": "Проведение опросов",
    "hint": "Если выбрали «Другое» — напишите, что именно",
    "conditional": {
      "show_if": {
        "data_purposes": "✅ Другое (укажу вручную)"
      }
    }
  },
  {
    "step": "consent_duration",
    "text": "⏱️ На какой срок даётся согласие:",
    "type": "single_select",
    "options": [
      "До отзыва пользователем",
      "3 года",
      "5 лет",
      "Другой срок (укажу вручную)"
    ],
    "required": true
  },
  {
    "step": "consent_duration_custom",
    "text": "📝 Укажите срок:",
    "type": "text",
    "required": false,
    "example": "1 год с момента регистрации",
    "hint": "Напишите срок полностью",
    "conditional": {
      "show_if": {
        "consent_duration": "Другой срок (укажу вручную)"
      }
    }
  },
  {
    "step": "withdrawal_method",
    "text": "📬 Как пользователь может отозвать согласие:",
    "type": "single_select",
    "options": [
      "✅ По письму на email",
      "✅ По письменному заявлению",
      "✅ Через личный кабинет на сайте",
      "✅ Другой способ (укажу вручную)"
    ],
    "required": true
  },
  {
    "step": "withdrawal_method_custom",
    "text": "📝 Укажите способ отзыва:",
    "type": "text",
    "required": false,
    "example": "Через форму обратной связи на сайте",
    "hint": "Если выбрали «Другой» — напишите, что именно",
    "conditional": {
      "show_if": {
        "withdrawal_method": "✅ Другой способ (укажу вручную)"
      }
    }
  }
]