  },
  {
    "step": "operator_type",
    "text": "👤 Владелец сайта — кто вы:",
    "type": "single_select",
    "options": [
      "ИП",
      "ООО",
      "Физ. лицо (самозанятый)",
      "Физ. лицо (не самозанятый)"
